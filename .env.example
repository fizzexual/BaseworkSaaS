# ════════════════════════════════════════════════════════════════════════
#  Basework environment
#
#  ✨ ZERO-CONFIG DEV: you can run `pnpm dev` with NO .env file at all.
#  When a variable below is empty, Basework falls back to an embedded /
#  mock implementation so the whole app works offline with no accounts:
#    • DATABASE_URL empty   → embedded PGlite (Postgres-in-process)
#    • STRIPE_* empty       → mock billing provider (simulated checkout)
#    • OPENAI/ANTHROPIC empty → mock AI provider (deterministic replies)
#    • RESEND_API_KEY empty → console email transport (logs the email)
#
#  To go to production, copy this file to `.env` and fill the values.
# ════════════════════════════════════════════════════════════════════════

# ─── Core ───────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
# Secret used to sign sessions. REQUIRED in production.
#   generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# ─── Database ────────────────────────────────────────────────────────────
# Empty → embedded PGlite (dev). In production set a Postgres URL (e.g. Neon):
#   postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=""

# ─── OAuth providers (optional) ─────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Stripe (optional — mock billing used when empty) ───────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── AI (optional — mock provider used when empty) ──────────────────────
# Set one to enable real streaming LLM responses.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
# Default model as "provider:model", e.g. "anthropic:claude-3-7-sonnet-latest"
# or "openai:gpt-4o-mini". Leave empty to use the mock provider.
AI_DEFAULT_MODEL=""

# ─── Email (optional — console transport when empty) ────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Basework <onboarding@resend.dev>"

# ─── Rate limiting (optional — in-memory when empty) ────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── UI ──────────────────────────────────────────────────────────────────
# Dashboard navigation layout: "sidebar" (default) or "topnav" (horizontal bar).
NEXT_PUBLIC_NAV_LAYOUT="sidebar"

# ─── Admin ───────────────────────────────────────────────────────────────
# Comma-separated emails granted super-admin (/admin) access.
SUPER_ADMIN_EMAILS="admin@basework.dev"

# ─── Encryption ──────────────────────────────────────────────────────────
# Encrypts BYO provider keys at rest (32+ chars). REQUIRED in prod if used.
ENCRYPTION_KEY=""
